{
  "manifest_version": 3,
  "name": "Apex Forge",
  "version": "0.1.0",
  "description": "Live activity feed for apex-forge browser automation",
  "permissions": ["sidePanel", "storage", "activeTab"],
  "host_permissions": ["http://127.0.0.1:*/"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["content.css"]
  }],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
